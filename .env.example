# Runtime
NODE_ENV=production
AUTH_SECRET=replace-with-at-least-32-random-characters
AUTH_DRIVER=local
ADMIN_EMAIL=admin@apgb.gw
ADMIN_NAME=Administrador APGB
ADMIN_PASSWORD=replace-with-a-strong-password

# Providers: local, supabase or mariadb
CONTENT_DRIVER=local
STORAGE_DRIVER=local

# Supabase configuration for Vercel
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=public-media

# MariaDB configuration for cPanel
DATABASE_URL=mysql://user:password@127.0.0.1:3306/apgb

# DeepL Free. Portuguese remains available when the key or quota is unavailable.
DEEPL_API_KEY=
DEEPL_API_URL=https://api-free.deepl.com/v2/translate
